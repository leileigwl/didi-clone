{
  "name": "didi-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "滴滴打车桌面应用 - Monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev:passenger": "pnpm --filter @didi/passenger dev",
    "dev:driver": "pnpm --filter @didi/driver dev",
    "dev:admin": "pnpm --filter @didi/admin dev",
    "dev:server": "pnpm --filter @didi/server dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
